    {
      "exercise_id": "ex_ch04_dt_002",
      "version": "v1",
      "title": "计算二分类节点的基尼指数",
      "type": "coding",
      "chapter_id": "ch04",
      "related_node_id": "ml_decision_tree",
      "assesses": ["ml_decision_tree"],
      "also_assesses": ["ml_performance_metrics"],
      "prerequisite_node_ids": ["ml_probability_statistics_basic"],
      "difficulty": 3,
      "estimated_minutes": 8,
      "cognitive_level": "apply",
      "assessment_focus": ["coding", "calculation"],
      "question": "补全 `gini_binary` 函数。输入一个节点中正类样本数 `pos` 和负类样本数 `neg`，返回该节点的二分类基尼指数。",
      "starter_code": "def gini_binary(pos, neg):\n    # TODO: gini = 1 - p_pos ** 2 - p_neg ** 2\n    pass\n",
      "options": [],
      "answer": {
        "reference_code": "def gini_binary(pos, neg):\n    total = pos + neg\n    if total == 0:\n        return 0\n    p_pos = pos / total\n    p_neg = neg / total\n    return 1 - p_pos ** 2 - p_neg ** 2\n",
        "explanation": "二分类节点的基尼指数为 1 - p_pos^2 - p_neg^2，越小表示节点越纯。"
      },
      "rubric": [
        {"criterion": "正确计算总样本数", "score": 1},
        {"criterion": "正确计算两个类别比例", "score": 1},
        {"criterion": "正确套用基尼指数公式", "score": 1},
        {"criterion": "处理空节点情况", "score": 1}
      ],
      "grading": {
        "method": "unit_test",
        "max_score": 4,
        "auto_gradable": true
      },
      "test_cases": [
        {
          "input": {"pos": 3, "neg": 1},
          "expected": 0.375
        },
        {
          "input": {"pos": 2, "neg": 2},
          "expected": 0.5
        },
        {
          "input": {"pos": 0, "neg": 0},
          "expected": 0
        }
      ],
      "adaptive_feedback": {
        "default": "请检查是否先计算类别比例，再代入 1 - sum(p_k^2)。",
        "common_errors": {
          "use_counts_directly": "你可能直接使用样本数平方，基尼指数需要类别比例。",
          "missing_empty_case": "如果节点样本数为 0，本题约定返回 0。"
        }
      },
      "profile_update_policy": {
        "on_correct": {
          "mastery_delta": 0.08,
