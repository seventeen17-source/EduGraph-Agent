# =============================================================
# EduGraph-Agent 环境变量模板
# 使用：复制本文件为 backend/.env，并填入你自己的密钥
#   cp 提交材料/部署配置/.env.example backend/.env
# 注意：切勿将填好真实密钥的 .env 提交到版本库或提交包
# =============================================================

# ---------- Neo4j 知识图谱 ----------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=edugraph123
NEO4J_DATABASE=neo4j

# ---------- LLM（OpenAI / DeepSeek 兼容端点） ----------
LLM_RESOLVER_ENABLED=true
LLM_PROVIDER=deepseek            # openai / deepseek
LLM_MODEL=deepseek-chat          # 或 gpt-4o-mini 等
LLM_API_KEY=your-llm-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1   # 使用官方 OpenAI 时可留空

# ---------- Embedding（语义记忆与课程语义检索） ----------
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B    # 或 text-embedding-3-small
EMBEDDING_API_KEY=your-embedding-api-key-here
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1   # 使用官方 OpenAI 时可留空

# ---------- SQLite 业务库（默认即可，无需修改） ----------
# DATABASE_URL=sqlite+aiosqlite:///../data/edugraph.db

# ---------- ChromaDB 持久化目录（默认即可） ----------
# CHROMA_PERSIST_DIR=../data/chroma

# ---------- 科大讯飞 图片生成（可选；不配置则图片资源类型不可用，其余功能不受影响） ----------
XUNFEI_IMAGE_PROVIDER=hidream    # hidream / tti
XUNFEI_TTI_ENABLED=false
XUNFEI_TTI_APP_ID=your-xunfei-app-id
XUNFEI_TTI_API_KEY=your-xunfei-api-key
XUNFEI_TTI_API_SECRET=your-xunfei-api-secret
XUNFEI_HIDREAM_ENABLED=false
XUNFEI_HIDREAM_CREATE_ENDPOINT=https://cn-huadong-1.xf-yun.com/v1/private/s3fd61810/create
XUNFEI_HIDREAM_QUERY_ENDPOINT=https://cn-huadong-1.xf-yun.com/v1/private/s3fd61810/query
XUNFEI_HIDREAM_ASPECT_RATIO=1:1
XUNFEI_HIDREAM_RESOLUTION=2k
GENERATED_ASSETS_BASE_URL=http://127.0.0.1:8000/generated-assets

# ---------- JWT（本地运行可留空；dev/prod 环境必填） ----------
# ENVIRONMENT=local
# JWT_SECRET=please-generate-a-long-random-secret
